# ─────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values
#  DO NOT commit .env — it is gitignored
# ─────────────────────────────────────────────────────────────────

# ── API Keys ──────────────────────────────────────────────────────
# Google AI Studio  →  https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Provider ──────────────────────────────────────────────────────
# Which provider to use: google | openai | anthropic
DEFAULT_PROVIDER=google

# ── Classification layers ─────────────────────────────────────────
# Layer 2: cheap LLM API call for ambiguous tasks
LAYER2_ENABLED=false

# Layer 3: on-prem embedding model (requires sentence-transformers + reference data)
LAYER3_ENABLED=false

# Layer 4: ML ensemble (enable only after 500+ logged classifications)
LAYER4_ENABLED=false

# ── Cascade confidence thresholds ─────────────────────────────────
# If a layer's confidence is below this, escalate to the next layer
LAYER3_CONFIDENCE_THRESHOLD=0.85
LAYER2_CONFIDENCE_THRESHOLD=0.75

# ── Cache ─────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_MAX_SIZE=10000
CACHE_TTL_SECS=3600

# ── Budget control ────────────────────────────────────────────────
# At 80% spend: cap tier at MEDIUM. At 100%: force LOW for all requests.
MONTHLY_BUDGET_USD=1000.0

# ── Decision logging ──────────────────────────────────────────────
# Logs to routing_decisions.jsonl in the working directory
LOG_DECISIONS=true
