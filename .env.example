# ─────────────────────────────────────────────
#  API Keys — copy this file to .env and fill in
# ─────────────────────────────────────────────

# Google AI Studio  →  https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────
#  Classifier settings
# ─────────────────────────────────────────────

# Which provider to use by default: google | openai | anthropic
DEFAULT_PROVIDER=google

# Layer 2: local Gemma model via Ollama (requires `ollama run gemma`)
LAYER2_ENABLED=false

# Layer 3: cheap API model for ambiguous tasks (Haiku / GPT-4o-mini)
LAYER3_ENABLED=false

# Layer 4: ML ensemble — only enable after 500+ logged classifications
LAYER4_ENABLED=false
