# ─────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values
#  DO NOT commit .env — it is gitignored
# ─────────────────────────────────────────────────────────────────

# ── API Keys ──────────────────────────────────────────────────────
# Google AI Studio  →  https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Provider ──────────────────────────────────────────────────────
# Which provider to use: google | openai | anthropic
DEFAULT_PROVIDER=google

# ── Classification layers ─────────────────────────────────────────
# Layer 2: LLM API call for ambiguous tasks (uses GOOGLE_API_KEY + gemini-2.5-flash-lite)
LAYER2_ENABLED=false
LAYER2_MODEL=gemini-2.5-flash-lite
LAYER2_TIMEOUT_MS=3500
LAYER2_MAX_RPM=100
LAYER2_FALLBACK_MODEL=           # optional: e.g. gpt-4o-mini — retries before returning None
LAYER2_MONTHLY_BUDGET_USD=0.0   # 0 = auto (5% of MONTHLY_BUDGET_USD)

# Layer 3: on-prem embedding model (requires sentence-transformers + reference data)
LAYER3_ENABLED=false

# Layer 4: ML ensemble (enable only after 500+ logged classifications)
LAYER4_ENABLED=false

# ── Cascade confidence thresholds ─────────────────────────────────
LAYER3_CONFIDENCE_THRESHOLD=0.85
LAYER2_CONFIDENCE_THRESHOLD=0.75

# ── Cache ─────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_MAX_SIZE=10000
CACHE_TTL_SECS=3600

# Semantic cache (embedding-based, requires sentence-transformers + numpy)
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.92

# ── Budget control ────────────────────────────────────────────────
# At 80% spend: cap tier at MEDIUM. At 100%: force LOW for all requests.
MONTHLY_BUDGET_USD=1000.0

# ── Decision logging ──────────────────────────────────────────────
# Logs to routing_decisions.jsonl in the project root
# PII spans are automatically redacted before writing
LOG_DECISIONS=true

# ── Debug / A/B testing ───────────────────────────────────────────
# Runs both L1 and L2 unconditionally and logs side-by-side (no routing change)
DEBUG_AB_MODE=false

# ── Test mode ─────────────────────────────────────────────────────
# When set: cost_tracker is a no-op, logs go to routing_decisions.test.jsonl
CLASSIFIER_TEST_MODE=false

# ── Domain keyword packs ──────────────────────────────────────────
# Comma-separated pack names from classifier/data/keyword_packs/
# Example: KEYWORD_PACKS=healthcare,fintech
KEYWORD_PACKS=
